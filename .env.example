# Hibi-BuBe Database Configuration
# Copy this file to .env and fill in your actual credentials

# Database Connection
DB_USER=hibiscus_user
DB_PASSWORD=your_password_here
DB_HOST=your_host
DB_PORT=mysql_port_of_your_host
DB_NAME=hibiscus

# Application Settings
LOG_LEVEL=INFO
LOG_FILE=logs/hibi-bube.log

# Export Settings
EXPORT_DIR=exports
TEMPLATE_DIR=templates

# GUI Settings
WINDOW_WIDTH=1200
WINDOW_HEIGHT=800
THEME=dark  # dark or light
